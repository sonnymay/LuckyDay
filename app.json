{
  "expo": {
    "name": "LuckyDay",
    "slug": "luckyday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEF0F5"
    },
    "ios": {
      "bundleIdentifier": "com.santipap.luckyday",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "LuckyDay saves your daily luck card to your photos so you can share it."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FEF0F5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "LuckyDay uses the camera to capture your face, palms, and handwriting during setup.",
          "photosPermission": "LuckyDay can use selected photos for your local luck profile.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "LuckyDay saves your daily luck card to your photos so you can share it."
        }
      ]
    ]
  }
}
